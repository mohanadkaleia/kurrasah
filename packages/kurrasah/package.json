{
  "name": "kurrasah",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Reusable Vue 3 + ProseMirror markdown editor with RTL support.",
  "main": "./dist/kurrasah.js",
  "module": "./dist/kurrasah.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/kurrasah.js"
    },
    "./style.css": "./dist/kurrasah.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "types/index.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "markdown-it": "^14"
  },
  "peerDependencies": {
    "prosemirror-commands": "^1",
    "prosemirror-history": "^1",
    "prosemirror-inputrules": "^1",
    "prosemirror-keymap": "^1",
    "prosemirror-markdown": "^1",
    "prosemirror-model": "^1",
    "prosemirror-schema-basic": "^1",
    "prosemirror-schema-list": "^1",
    "prosemirror-state": "^1",
    "prosemirror-view": "^1",
    "vue": "^3.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.2",
    "prosemirror-model": "^1.25.3",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.40.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.4",
    "vitest": "^2.1.9",
    "vue": "^3.5.32"
  }
}
